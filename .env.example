DEBUG=True
SECRET_KEY=change-me-to-a-random-value

TELEGRAM_BOT_TOKEN=

# Shared secret Telegram echoes back on every webhook call. The webhook REFUSES to run
# without it. Generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=

PREMIUM_CARD_NUMBER=0000 0000 0000 0000
PREMIUM_CARD_HOLDER=Ism Familiya

# Public HTTPS base URL — used for the Mini App button and to build the webhook URL.
WEBAPP_URL=https://example.com
ADMIN_TELEGRAM_CHAT_ID=

# --- Scale (leave empty for local dev; both are single-line switches) --------------
# PostgreSQL. SQLite serialises every write behind one lock and cannot handle real
# concurrency — set this before going live.
DATABASE_URL=
CONN_MAX_AGE=60
DB_SSL_REQUIRE=False

# Redis. When set, the cache AND sessions move to Redis automatically (shared across
# every gunicorn worker instead of per-process).
REDIS_URL=

# Gunicorn sizing (see gunicorn.conf.py)
WEB_CONCURRENCY=
GUNICORN_THREADS=4

# Groq Cloud API (https://console.groq.com) — powers the AI Mentor chat and the
# post-test AI feedback. Leave empty to fall back to the built-in rule-based logic.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Lokal Ollama zaxira (ixtiyoriy): Groq ishlamasa AI funksiyalari shu lokal
# serverdan javob oladi. Bo'sh qoldirilsa zaxira o'chirilgan.
OLLAMA_API_URL=
OLLAMA_AI_MODEL=qwen3:8b
